# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|  
    
    config.vm.define "K3d" do |k3d|

        k3d.vm.box = "debian/bookworm64"
        k3d.vm.hostname = "k3d-server"
        k3d.vm.provider "virtualbox" do |vb|
            vb.memory = "2048"
            vb.cpus = 2
        end
        k3d.vm.network "private_network", ip: "192.168.56.120"

        k3d.vm.provision "shell", inline: <<-SHELL
            apt-get update -y
            apt-get install -y curl wget git
        SHELL

        k3d.vm.provision "file", source: "scripts/install.sh", destination: "/home/vagrant/install.sh"
        k3d.vm.provision "file", source: "scripts/setup-argocd.sh", destination: "/home/vagrant/setup-argocd.sh"
        k3d.vm.provision "file", source: "confs", destination: "/home/vagrant/confs"

        k3d.vm.provision "shell", inline: <<-SHELL
            chmod +x /home/vagrant/install.sh
            chmod +x /home/vagrant/setup-argocd.sh
            bash /home/vagrant/install.sh
        SHELL
    end

end
